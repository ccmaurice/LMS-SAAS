# Copy to .env (and optionally .env.local for overrides). Next.js loads .env then .env.local.
# Prisma CLI reads prisma.config.ts + dotenv.

# --- PostgreSQL (Prisma) — Supabase or local Docker ---
# Supabase (app runtime): Project Settings → Database → Connection string → URI → Transaction pooler (port 6543).
#   Append: ?pgbouncer=true  (and sslmode=require if not already in the URL)
# Supabase (migrations): use "Session mode" or direct connection (port 5432) as DIRECT_URL so migrate deploy can use advisory locks.
# Local Docker: postgresql://saaslms:saaslms@127.0.0.1:5432/saaslms
DATABASE_URL="postgresql://saaslms:saaslms@127.0.0.1:5432/saaslms"
# Hosted Postgres (Supabase/Vercel): keep TLS in the URL (e.g. sslmode=require). For stricter verification later, sslmode=verify-full is recommended where your provider documents it.
# Optional on Supabase (required for prisma migrate deploy on CI/Vercel when DATABASE_URL is the pooler):
# DIRECT_URL="postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres"

# JWT signing — required; at least 16 characters or /o/* routes will refuse to load (proxy guard).
# Prefer 32+ random bytes in production.
JWT_SECRET="replace-with-a-long-random-secret-in-production"

# After migrate: npm run db:seed — demo org slug `demo-school`, users admin|teacher|student@test.com / password123
# Hide the long “Local demo” box on /login in development (set in .env.local after you’re set up):
# NEXT_PUBLIC_HIDE_DEMO_LOGIN_HINT="1"

# Optional: OpenAI for AI exams / grading / feedback (omit to use built-in mocks)
OPENAI_API_KEY=""

# Optional: Gemini for PDF → questions (GOOGLE_AI_API_KEY or GEMINI_API_KEY)

# Public app URL (OAuth callbacks, emails)
# Canonical public origin (no trailing slash). In production use your custom domain or Vercel URL, e.g. https://lms.example.org
# Must be a valid http(s) URL if set (validated server-side in src/lib/env/server-public.ts).
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Google OAuth — set NEXT_PUBLIC_GOOGLE_CLIENT_ID to the same web client ID as GOOGLE_CLIENT_ID (shows “Continue with Google” on /login)
# Authorized redirect URI: {NEXT_PUBLIC_APP_URL}/api/auth/google/callback
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""
# NEXT_PUBLIC_GOOGLE_CLIENT_ID=""

# Transactional email (invites) via Resend — omit to log only in development
# RESEND_API_KEY=""
# EMAIL_FROM="LMS <onboarding@resend.dev>"

# Optional: directory for uploaded lesson files (default: ./uploads) when not using Blob
# UPLOAD_DIR=""

# Vercel Blob (Production/Preview): read-write token from Vercel → Storage → Blob. When set, uploads go to Blob and DB stores full blob URLs; omit for local disk only.
# BLOB_READ_WRITE_TOKEN=""

# Platform operator (super admin) - enables /platform
# PLATFORM_ADMIN_EMAIL="platform@local"
# PLATFORM_ADMIN_PASSWORD="change-me"
# PLATFORM_JWT_SECRET="change-me-long-random" # min 16 chars (same guard as /platform proxy)

# Development: disable one-click demo session at /api/dev/quick-login when exposing the dev server
# DISABLE_DEV_QUICK_LOGIN="true"

# Rate limits (login, register, OAuth, invites) use the client IP from X-Forwarded-For / CF-Connecting-Ip — configure your reverse proxy to set or sanitize those headers.

# Optional: edge middleware logs one JSON line per matched request (method, path, orgSlug when /o/..., area=platform); response includes X-Request-Id. No PII.
# ENABLE_REQUEST_LOG="true"

# Optional: full DB backup/restore from /platform/database — only when DATABASE_URL is mysql:// (legacy)
# ENABLE_PLATFORM_DATABASE_TOOLS="true"

# Optional: cap serverless pg pool size (default 15)
# PG_POOL_MAX="15"

# Quick start: docker compose up postgres adminer -d  then  npm run db:bootstrap

# --- Vercel (https://vercel.com) ---
# 1. DATABASE_URL: Supabase transaction pooler (6543) + pgbouncer=true for runtime.
# 2. DIRECT_URL: Supabase direct/session (5432) for Production builds — prisma migrate deploy uses prisma.config.ts (DIRECT_URL || DATABASE_URL).
# 3. NEXT_PUBLIC_APP_URL: https://your-app.vercel.app (no trailing slash).
# 4. BLOB_READ_WRITE_TOKEN for persistent uploads (see docs/vercel-deploy.md).
# Build: node scripts/vercel-build.mjs runs prisma migrate deploy only in Production, then next build.

# --- Translation tool (/tools/translate) — optional ---
# Without these, the API uses the free MyMemory endpoint (short texts only; quotas apply).
# LibreTranslate (self-hosted or https://libretranslate.com): POST /translate JSON body.
# LIBRETRANSLATE_API_URL="https://libretranslate.com"
# LIBRETRANSLATE_API_KEY=""  # if your instance requires it
# Optional: higher MyMemory daily limit when you add a contact email (see mymemory.translated.net usage limits)
# MYMEMORY_CONTACT_EMAIL="you@example.com"

# Whole-site language (floating “Site language” button) uses Google’s free web translator — no API key.
# Set to "1" only if you want to hide it (e.g. strict privacy policy).
# NEXT_PUBLIC_DISABLE_SITE_TRANSLATE="1"
