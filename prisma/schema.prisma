// SaaS LMS — multi-tenant PostgreSQL schema (Prisma 7; Supabase-compatible)

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  TEACHER
  STUDENT
}

enum QuestionType {
  MCQ
  SHORT_ANSWER
  LONG_ANSWER
  TRUE_FALSE
}

enum GradingScaleType {
  PERCENTAGE
  LETTER_AF
  NUMERIC_10
}

enum PromotionStanding {
  PASS
  PROBATION
  RETAIN
}

enum AssessmentKind {
  QUIZ
  EXAM
}

enum SubmissionStatus {
  DRAFT
  SUBMITTED
  GRADED
}

enum LearningResourceKind {
  PDF
  VIDEO
  LINK
  OTHER
}

/// School-wide wall: members post as themselves; platform operators post as PLATFORM.
enum OrgMessageSenderKind {
  MEMBER
  PLATFORM
}

enum OrganizationStatus {
  ACTIVE
  PENDING
  REJECTED
}

model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  subdomain String?  @unique
  /// New self-serve schools start PENDING until a platform operator approves.
  status    OrganizationStatus @default(ACTIVE)
  /// When false, students do not see report card content (staff still can).
  reportCardsPublished   Boolean  @default(true)
  /// When false, students cannot open completion certificates.
  certificatesPublished  Boolean  @default(true)
  /// Display label for the current academic year (promotion & report cards).
  academicYearLabel         String   @default("2025-2026")
  /// Cumulative percent ≥ this → PASS (promotion engine).
  promotionPassMinPercent   Float    @default(60)
  /// Cumulative percent ≥ this and < pass → PROBATION.
  promotionProbationMinPercent Float @default(50)
  /// Preset key: DEFAULT, SLATE, VIOLET, EMERALD, ROSE, AMBER
  themeTemplate         String   @default("DEFAULT")
  /// Optional #RRGGBB override for primary brand color (light mode; dark is derived).
  customPrimaryHex      String?
  customAccentHex       String?
  /// Shown on the platform landing carousel and as default hero art for the public school page (https URL).
  heroImageUrl          String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users             User[]
  invites           UserInvite[]
  courses           Course[]
  cmsEntries        CmsEntry[]
  blogPosts         BlogPost[]
  learningResources LearningResource[]
  schoolMessages    OrganizationMessage[]
  directMessageThreads DirectMessageThread[]
  scoreOverrideLogs     ScoreOverrideLog[]
  promotionSnapshots      StudentPromotionSnapshot[]
}

/// Optional profile fields for platform console operators (env-based login).
model PlatformProfile {
  id        String   @id @default(cuid())
  email     String   @unique
  /// Google-style URL or local storage key under uploads (see `lib/profile/avatar-storage`).
  image     String?
  updatedAt DateTime @updatedAt
}

/// Global marketing home page (/). Edited by platform operators only.
model PlatformSetting {
  key       String   @id
  value     String   @db.Text
  updatedAt DateTime @updatedAt
}

/// In-app alerts for the platform console (no org user row).
model PlatformNotification {
  id        String   @id @default(cuid())
  type      String
  title     String
  body      String?  @db.Text
  link      String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([read, createdAt(sort: Desc)])
}

model User {
  id             String    @id @default(cuid())
  email          String
  passwordHash   String?
  /// Google subject (`sub`) for OAuth sign-in; unique per organization
  googleSub      String?
  name           String?
  role           Role      @default(STUDENT)
  image          String?
  /// When set, the user cannot sign in or use API as an active member.
  suspendedAt    DateTime?
  organizationId String
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  coursesCreated   Course[]       @relation("CourseAuthor")
  enrollments      Enrollment[]
  lessonProgress   LessonProgress[]
  assessmentsAuthored Assessment[]  @relation("AssessmentAuthor")
  submissions      Submission[]
  answersGraded    Answer[]       @relation("AnswerGradedBy")
  invitesSent      UserInvite[]   @relation("InviteCreatedBy")
  notifications    Notification[]
  blogPosts        BlogPost[]
  courseChatMessages CourseChatMessage[]
  resourceProgress ResourceProgress[]
  schoolMessages     OrganizationMessage[]
  dmThreadsAsLow     DirectMessageThread[] @relation("DmThreadLow")
  dmThreadsAsHigh    DirectMessageThread[] @relation("DmThreadHigh")
  directMessagesSent DirectMessage[]
  scoreOverridesAsEditor ScoreOverrideLog[] @relation("ScoreOverrideEditor")
  promotionSnapshots     StudentPromotionSnapshot[]

  @@unique([organizationId, email])
  @@unique([organizationId, googleSub])
  @@index([organizationId])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  body      String?
  link      String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@index([userId, createdAt(sort: Desc)])
}

model UserInvite {
  id             String   @id @default(cuid())
  organizationId String
  email          String
  role           Role     @default(STUDENT)
  token          String   @unique
  expiresAt      DateTime
  createdAt      DateTime @default(now())
  createdById    String?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy    User?        @relation("InviteCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([organizationId])
}

model Course {
  id             String   @id @default(cuid())
  organizationId String
  title          String
  description    String?  @db.Text
  published      Boolean  @default(false)
  /// CA vs exam weighting uses Assessment.kind (QUIZ vs EXAM). Optional 1–3 for multi-semester rollups.
  gradeWeightContinuous Float            @default(0.4)
  gradeWeightExam       Float            @default(0.6)
  gradingScale          GradingScaleType @default(PERCENTAGE)
  createdById    String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy    User         @relation("CourseAuthor", fields: [createdById], references: [id], onDelete: Restrict)

  modules       Module[]
  enrollments   Enrollment[]
  assessments   Assessment[]
  chatMessages  CourseChatMessage[]

  @@index([organizationId])
}

/// Headless CMS strings per organization (no redeploy for copy changes)
model CmsEntry {
  id             String   @id @default(cuid())
  organizationId String
  key            String
  value          String   @db.Text
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, key])
  @@index([organizationId])
}

model BlogPost {
  id             String   @id @default(cuid())
  organizationId String
  slug           String
  title          String
  excerpt        String?  @db.Text
  body           String   @db.Text
  published      Boolean  @default(false)
  authorId       String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  author       User         @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@unique([organizationId, slug])
  @@index([organizationId, published])
}

model LearningResource {
  id             String               @id @default(cuid())
  organizationId String
  title          String
  description    String?              @db.Text
  kind           LearningResourceKind
  externalUrl    String?
  storageKey     String?              @unique
  mimeType       String?
  sortOrder      Int                  @default(0)
  published      Boolean              @default(true)
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  organization Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  progress     ResourceProgress[]

  @@index([organizationId, published])
}

model ResourceProgress {
  id          String   @id @default(cuid())
  userId      String
  resourceId  String
  positionSec Float?
  percent     Float    @default(0)
  updatedAt   DateTime @updatedAt

  user     User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  resource LearningResource @relation(fields: [resourceId], references: [id], onDelete: Cascade)

  @@unique([userId, resourceId])
  @@index([resourceId])
}

model CourseChatMessage {
  id        String   @id @default(cuid())
  courseId  String
  userId    String
  body      String   @db.Text
  createdAt DateTime @default(now())

  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([courseId, createdAt])
}

/// Organization-wide chat visible to all members; platform operators can post from the console.
model OrganizationMessage {
  id               String               @id @default(cuid())
  organizationId   String
  senderKind       OrgMessageSenderKind
  userId           String?
  platformEmail    String?
  body             String               @db.Text
  createdAt        DateTime             @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User?        @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([organizationId, createdAt(sort: Desc)])
}

/// 1:1 DM thread between two org members (participants stored with deterministic ordering).
model DirectMessageThread {
  id                String   @id @default(cuid())
  organizationId    String
  participantLowId  String
  participantHighId String
  lastMessageAt     DateTime @default(now())

  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  participantLow  User         @relation("DmThreadLow", fields: [participantLowId], references: [id], onDelete: Cascade)
  participantHigh User         @relation("DmThreadHigh", fields: [participantHighId], references: [id], onDelete: Cascade)
  messages        DirectMessage[]

  @@unique([organizationId, participantLowId, participantHighId])
  @@index([organizationId])
  @@index([participantLowId])
  @@index([participantHighId])
  @@index([organizationId, lastMessageAt(sort: Desc)])
}

model DirectMessage {
  id        String   @id @default(cuid())
  threadId  String
  senderId  String
  body      String   @db.Text
  createdAt DateTime @default(now())

  thread DirectMessageThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  sender User                @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([threadId, createdAt])
}

model Module {
  id       String @id @default(cuid())
  courseId String
  title    String
  order    Int    @default(0)

  course  Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons Lesson[]

  @@index([courseId])
}

model Lesson {
  id        String  @id @default(cuid())
  moduleId  String
  title     String
  content   String? @db.Text
  order     Int     @default(0)
  videoUrl  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  module   Module         @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  files    LessonFile[]
  progress LessonProgress[]

  @@index([moduleId])
}

model LessonFile {
  id         String   @id @default(cuid())
  lessonId   String
  name       String
  url        String
  mimeType   String?
  /// Relative path under upload root; null = external URL only (see `url`)
  storageKey String?  @unique
  createdAt  DateTime @default(now())

  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@index([lessonId])
}

model Enrollment {
  id               String   @id @default(cuid())
  userId           String
  courseId         String
  enrolledAt       DateTime @default(now())
  progressPercent  Float    @default(0)

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@index([courseId])
}

model LessonProgress {
  id          String   @id @default(cuid())
  userId      String
  lessonId    String
  completedAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
  @@index([lessonId])
}

model Assessment {
  id               String         @id @default(cuid())
  courseId         String
  title            String
  description      String?        @db.Text
  kind             AssessmentKind @default(QUIZ)
  /// 1, 2, or 3 for multi-semester promotion rollups; null = not tagged to a semester.
  semester         Int?
  timeLimitMinutes Int?
  published        Boolean        @default(false)
  shuffleQuestions Boolean        @default(false)
  createdById      String
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  course      Course       @relation(fields: [courseId], references: [id], onDelete: Cascade)
  createdBy   User         @relation("AssessmentAuthor", fields: [createdById], references: [id], onDelete: Restrict)
  questions   Question[]
  submissions Submission[]

  @@index([courseId])
}

model Question {
  id              String       @id @default(cuid())
  assessmentId    String
  type            QuestionType
  prompt          String       @db.Text
  order           Int          @default(0)
  points          Float        @default(1)
  /// MCQ: { "choices": [{ "id": string, "text": string, "correct": boolean }] }
  options         Json?
  correctAnswer   String?
  markingScheme   String?      @db.Text
  /// Optional multimodal refs: [{ "kind": "image"|"video"|"audio", "url": "https://..." }]
  mediaAttachments Json?

  assessment Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  answers    Answer[]

  @@index([assessmentId])
}

model Submission {
  id          String           @id @default(cuid())
  assessmentId String
  userId      String
  startedAt   DateTime         @default(now())
  submittedAt DateTime?
  status      SubmissionStatus @default(DRAFT)
  totalScore  Float?
  maxScore    Float?

  assessment Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  answers    Answer[]

  @@index([assessmentId])
  @@index([userId])
}

model Answer {
  id            String  @id @default(cuid())
  submissionId  String
  questionId    String
  content       String  @db.Text
  autoGraded    Boolean @default(false)
  score         Float?
  aiScore       Float?
  aiFeedback    String? @db.Text
  manualScore   Float?
  manualComment String? @db.Text
  gradedById    String?
  manualEditedAt DateTime?

  submission Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  question   Question   @relation(fields: [questionId], references: [id], onDelete: Cascade)
  gradedBy   User?      @relation("AnswerGradedBy", fields: [gradedById], references: [id], onDelete: SetNull)
  overrideLogs ScoreOverrideLog[]

  @@unique([submissionId, questionId])
  @@index([questionId])
}

model ScoreOverrideLog {
  id                  String   @id @default(cuid())
  answerId            String
  organizationId      String
  editorId            String
  previousManualScore Float?
  newManualScore      Float
  createdAt           DateTime @default(now())

  answer       Answer       @relation(fields: [answerId], references: [id], onDelete: Cascade)
  editor       User         @relation("ScoreOverrideEditor", fields: [editorId], references: [id], onDelete: Restrict)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, createdAt(sort: Desc)])
  @@index([answerId])
}

model StudentPromotionSnapshot {
  id                   String            @id @default(cuid())
  organizationId       String
  userId               String
  academicYearLabel    String
  semester1AvgPercent  Float?
  semester2AvgPercent  Float?
  semester3AvgPercent  Float?
  cumulativeAvgPercent Float?
  standing             PromotionStanding
  computedAt           DateTime          @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId, academicYearLabel])
  @@index([organizationId])
}
