// SaaS LMS — multi-tenant PostgreSQL schema (Prisma 7; Supabase-compatible)

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  TEACHER
  STUDENT
  PARENT
}

enum EducationLevel {
  PRIMARY
  SECONDARY
  HIGHER_ED
}

enum QuestionType {
  MCQ
  SHORT_ANSWER
  LONG_ANSWER
  TRUE_FALSE
  DRAG_DROP
  ESSAY_RICH
  FORMULA
}

enum SubmissionModerationState {
  NONE
  FIRST_REVIEW
  SECOND_REVIEW
  EXTERNAL_REVIEW
  APPROVED
}

enum GradingScaleType {
  PERCENTAGE
  LETTER_AF
  NUMERIC_10
}

enum PromotionStanding {
  PASS
  PROBATION
  RETAIN
}

enum AssessmentKind {
  QUIZ
  EXAM
}

/// Scheduled moments or windows for an assessment (dashboard calendar, notifications). Replaces ad-hoc availableFrom/dueAt when entries exist.
enum AssessmentScheduleKind {
  CA_OPENS
  CA_DUE
  EXAM_WINDOW
}

/// School-wide calendar entries (resumption, breaks, events) managed by admins.
enum SchoolCalendarEventKind {
  RESUMPTION
  CLOSURE
  HOLIDAY
  EVENT
  ACTIVITY
  OTHER
}

/// How the student take experience behaves: practice vs monitored browser vs stricter lockdown-style UI.
enum AssessmentDeliveryMode {
  FORMATIVE
  SECURE_ONLINE
  LOCKDOWN
}

enum SubmissionStatus {
  DRAFT
  SUBMITTED
  GRADED
}

enum RetakeRequestStatus {
  PENDING
  APPROVED
  DENIED
}

enum LearningResourceKind {
  PDF
  VIDEO
  LINK
  OTHER
}

/// School-wide wall: members post as themselves; platform operators post as PLATFORM.
enum OrgMessageSenderKind {
  MEMBER
  PLATFORM
}

enum OrganizationStatus {
  ACTIVE
  PENDING
  REJECTED
}

/// Curriculum family for shared question bank items (IB, Cambridge, AP style prompts).
enum QuestionBankFramework {
  IB
  CAMBRIDGE
  AP
}

model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  subdomain String?  @unique
  /// New self-serve schools start PENDING until a platform operator approves.
  status    OrganizationStatus @default(ACTIVE)
  /// When false, students do not see report card content (staff still can).
  reportCardsPublished   Boolean  @default(true)
  /// When false, students cannot open completion certificates.
  certificatesPublished  Boolean  @default(true)
  /// Display label for the current academic year (promotion & report cards).
  academicYearLabel         String   @default("2025-2026")
  /// Cumulative percent ≥ this → PASS (promotion engine).
  promotionPassMinPercent   Float    @default(60)
  /// Cumulative percent ≥ this and < pass → PROBATION.
  promotionProbationMinPercent Float @default(50)
  /// Preset key: DEFAULT, SLATE, VIOLET, EMERALD, ROSE, AMBER
  themeTemplate         String   @default("DEFAULT")
  /// Optional #RRGGBB override for primary brand color (light mode; dark is derived).
  customPrimaryHex      String?
  customAccentHex       String?
  /// Shown on the platform landing carousel and as default hero art for the public school page (https URL).
  heroImageUrl          String?
  /// Optional square/wide logo for app shell, transcripts, report cards, certificates, PDFs. When null, hero/CMS image is used.
  logoImageUrl          String?
  /// Universal platform: primary / secondary / higher-ed drives grading & terminology defaults.
  educationLevel        EducationLevel @default(SECONDARY)
  /// JSON: terminology map, letter bands, GPA config, reportShowRank, feature flags (see education_context schema).
  organizationSettings  Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users             User[]
  invites           UserInvite[]
  courses           Course[]
  cmsEntries        CmsEntry[]
  blogPosts         BlogPost[]
  learningResources LearningResource[]
  schoolMessages    OrganizationMessage[]
  directMessageThreads DirectMessageThread[]
  scoreOverrideLogs     ScoreOverrideLog[]
  promotionSnapshots      StudentPromotionSnapshot[]
  parentLinks             ParentStudentLink[]       @relation("ParentOrg")
  learningStandards       LearningStandard[]
  questionBankItems       QuestionBankItem[]
  gradingAuditLogs        GradingAuditLog[]
  proctoringEvents        ProctoringEvent[]
  academicTerms           AcademicTerm[]
  schoolCalendarEvents    SchoolCalendarEvent[]
  schoolCohorts           SchoolCohort[]
  facultyDivisions        FacultyDivision[]
  academicDepartments     AcademicDepartment[]
  courseCompletionCertificates CourseCompletionCertificate[]
}

/// Academic period (term/semester) — attach to courses; mark one as current for school-wide UI.
model AcademicTerm {
  id             String    @id @default(cuid())
  organizationId String
  code           String
  label          String
  startDate      DateTime?
  endDate        DateTime?
  sortOrder      Int       @default(0)
  isCurrent      Boolean   @default(false)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  courses      Course[]

  @@unique([organizationId, code])
  @@index([organizationId])
}

model SchoolCalendarEvent {
  id             String                   @id @default(cuid())
  organizationId String
  kind           SchoolCalendarEventKind  @default(EVENT)
  title          String
  description    String?                  @db.Text
  /// When `allDay` is true, store start-of-day / end-of-day in UTC for the chosen calendar date.
  startsAt       DateTime
  endsAt         DateTime?
  allDay         Boolean                  @default(false)
  createdById    String?
  createdAt      DateTime                 @default(now())
  updatedAt      DateTime                 @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy    User?        @relation("SchoolCalendarEventAuthor", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([organizationId, startsAt])
}

/// Prevents duplicate in-app notifications for the same calendar signal per user.
model CalendarNotificationDedupe {
  id        String   @id @default(cuid())
  userId    String
  dedupeKey String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, dedupeKey])
  @@index([userId])
}

/// Primary / secondary homeroom or form group (students assigned by admin).
model SchoolCohort {
  id                  String   @id @default(cuid())
  organizationId      String
  name                String
  gradeLabel          String?
  /// Secondary: optional pathway / stream (e.g. Science, Arts, vocational track).
  trackLabel          String?
  academicYearLabel   String   @default("")
  homeroomTeacherId   String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  homeroomTeacher User?        @relation("HomeroomTeacher", fields: [homeroomTeacherId], references: [id], onDelete: SetNull)
  members         CohortMembership[]
  instructors     CohortInstructor[]
  courseLinks     CourseCohort[]
  assessmentTargets AssessmentCohort[]
  messages        CohortMessage[]

  @@index([organizationId])
}

/// Additional teachers assigned to a class (homeroom teacher is also tracked on SchoolCohort).
model CohortInstructor {
  cohortId String
  userId   String

  cohort SchoolCohort @relation(fields: [cohortId], references: [id], onDelete: Cascade)
  user   User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([cohortId, userId])
  @@index([userId])
}

/// Course offered to a specific school class (used for assessment targeting & class context).
model CourseCohort {
  courseId String
  cohortId String

  course Course       @relation(fields: [courseId], references: [id], onDelete: Cascade)
  cohort SchoolCohort @relation(fields: [cohortId], references: [id], onDelete: Cascade)

  @@id([courseId, cohortId])
  @@index([cohortId])
}

/// When empty, all enrolled students may see the assessment; when set, only students in those classes (who are enrolled).
model AssessmentCohort {
  assessmentId String
  cohortId     String

  assessment Assessment   @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  cohort     SchoolCohort @relation(fields: [cohortId], references: [id], onDelete: Cascade)

  @@id([assessmentId, cohortId])
  @@index([cohortId])
}

/// Teacher → class announcements (read by class members and instructors).
model CohortMessage {
  id        String   @id @default(cuid())
  cohortId  String
  userId    String
  body      String   @db.Text
  createdAt DateTime @default(now())

  cohort SchoolCohort @relation(fields: [cohortId], references: [id], onDelete: Cascade)
  user   User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([cohortId, createdAt(sort: Desc)])
}

/// Higher-ed: faculty / school umbrella (e.g. Faculty of Science).
model FacultyDivision {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  code           String?
  sortOrder      Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  departments  AcademicDepartment[]

  @@index([organizationId])
}

/// Higher-ed: department or program unit (mirrors class/cohort for messaging & assessment targeting).
model AcademicDepartment {
  id                String   @id @default(cuid())
  organizationId    String
  facultyDivisionId String?
  name              String
  code              String?
  chairUserId       String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  facultyDivision FacultyDivision? @relation(fields: [facultyDivisionId], references: [id], onDelete: SetNull)
  chair           User?          @relation("DepartmentChair", fields: [chairUserId], references: [id], onDelete: SetNull)
  instructors     DepartmentInstructor[]
  studentAffiliations StudentDepartmentAffiliation[]
  courseLinks     CourseDepartment[]
  assessmentTargets AssessmentDepartment[]
  messages        DepartmentMessage[]

  @@index([organizationId])
  @@index([facultyDivisionId])
}

model DepartmentInstructor {
  departmentId String
  userId       String

  department AcademicDepartment @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  user       User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([departmentId, userId])
  @@index([userId])
}

model StudentDepartmentAffiliation {
  departmentId String
  userId       String
  isPrimary    Boolean  @default(true)
  createdAt    DateTime @default(now())

  department AcademicDepartment @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  user       User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([departmentId, userId])
  @@index([userId])
}

model CourseDepartment {
  courseId     String
  departmentId String

  course     Course             @relation(fields: [courseId], references: [id], onDelete: Cascade)
  department AcademicDepartment @relation(fields: [departmentId], references: [id], onDelete: Cascade)

  @@id([courseId, departmentId])
  @@index([departmentId])
}

model AssessmentDepartment {
  assessmentId String
  departmentId String

  assessment Assessment         @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  department AcademicDepartment @relation(fields: [departmentId], references: [id], onDelete: Cascade)

  @@id([assessmentId, departmentId])
  @@index([departmentId])
}

model DepartmentMessage {
  id           String   @id @default(cuid())
  departmentId String
  userId       String
  body         String   @db.Text
  createdAt    DateTime @default(now())

  department AcademicDepartment @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  user       User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([departmentId, createdAt(sort: Desc)])
}

model CohortMembership {
  cohortId  String
  userId    String
  createdAt DateTime @default(now())

  cohort SchoolCohort @relation(fields: [cohortId], references: [id], onDelete: Cascade)
  user   User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([cohortId, userId])
  @@index([userId])
}

/// Links a parent user to a student in the same organization.
model ParentStudentLink {
  id             String   @id @default(cuid())
  organizationId String
  parentUserId   String
  studentUserId  String
  createdAt      DateTime @default(now())

  organization Organization @relation("ParentOrg", fields: [organizationId], references: [id], onDelete: Cascade)
  parent       User         @relation("ParentOf", fields: [parentUserId], references: [id], onDelete: Cascade)
  student      User         @relation("StudentOf", fields: [studentUserId], references: [id], onDelete: Cascade)

  @@unique([organizationId, parentUserId, studentUserId])
  @@index([parentUserId])
  @@index([studentUserId])
}

/// Competency / standard catalog per org.
model LearningStandard {
  id             String   @id @default(cuid())
  organizationId String
  code           String
  title          String
  description    String?  @db.Text

  organization Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  questions    QuestionStandard[]

  @@unique([organizationId, code])
  @@index([organizationId])
}

model QuestionStandard {
  questionId String
  standardId String

  question Question         @relation(fields: [questionId], references: [id], onDelete: Cascade)
  standard LearningStandard @relation(fields: [standardId], references: [id], onDelete: Cascade)

  @@id([questionId, standardId])
  @@index([standardId])
}

/// Reusable assessment items (platform-wide when organizationId is null; org-scoped when set).
model QuestionBankItem {
  id             String                @id @default(cuid())
  organizationId String?
  framework      QuestionBankFramework
  subject        String
  gradeLabel     String?
  standardCode   String?
  type           QuestionType
  prompt         String                @db.Text
  points         Float                 @default(1)
  options        Json?
  correctAnswer  String?
  markingScheme  String?               @db.Text
  questionSchema Json?

  createdAt DateTime @default(now())

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([framework, subject])
}

/// Client-reported proctoring signals (blur, fullscreen exit, etc.).
model ProctoringEvent {
  id             String   @id @default(cuid())
  organizationId String
  userId         String
  assessmentId   String?
  submissionId   String?
  eventType      String
  payload        Json?
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([assessmentId])
  @@index([organizationId, createdAt(sort: Desc)])
  @@index([userId])
}

model GradingAuditLog {
  id             String   @id @default(cuid())
  organizationId String
  actorId        String
  entityType     String
  entityId       String
  action         String
  payload        Json?
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  actor        User           @relation("GradingAuditActor", fields: [actorId], references: [id], onDelete: Cascade)

  @@index([entityId])
  @@index([organizationId, createdAt(sort: Desc)])
}

/// Optional profile fields for platform console operators (env-based login).
model PlatformProfile {
  id        String   @id @default(cuid())
  email     String   @unique
  /// Google-style URL or local storage key under uploads (see `lib/profile/avatar-storage`).
  image     String?
  updatedAt DateTime @updatedAt
}

/// Global marketing home page (/). Edited by platform operators only.
model PlatformSetting {
  key       String   @id
  value     String   @db.Text
  updatedAt DateTime @updatedAt
}

/// In-app alerts for the platform console (no org user row).
model PlatformNotification {
  id        String   @id @default(cuid())
  type      String
  title     String
  body      String?  @db.Text
  link      String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([read, createdAt(sort: Desc)])
}

model User {
  id             String    @id @default(cuid())
  email          String
  passwordHash   String?
  /// Google subject (`sub`) for OAuth sign-in; unique per organization
  googleSub      String?
  name           String?
  role           Role      @default(STUDENT)
  image          String?
  /// When set, the user cannot sign in or use API as an active member.
  suspendedAt    DateTime?
  organizationId String
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  coursesCreated   Course[]       @relation("CourseAuthor")
  enrollments      Enrollment[]
  lessonProgress   LessonProgress[]
  assessmentsAuthored Assessment[]  @relation("AssessmentAuthor")
  submissions      Submission[]
  answersGraded    Answer[]       @relation("AnswerGradedBy")
  invitesSent      UserInvite[]   @relation("InviteCreatedBy")
  notifications    Notification[]
  calendarNotificationDedupes CalendarNotificationDedupe[]
  schoolCalendarEventsAuthored  SchoolCalendarEvent[] @relation("SchoolCalendarEventAuthor")
  blogPosts        BlogPost[]
  courseChatMessages CourseChatMessage[]
  resourceProgress ResourceProgress[]
  schoolMessages     OrganizationMessage[]
  dmThreadsAsLow     DirectMessageThread[] @relation("DmThreadLow")
  dmThreadsAsHigh    DirectMessageThread[] @relation("DmThreadHigh")
  directMessagesSent DirectMessage[]
  scoreOverridesAsEditor ScoreOverrideLog[] @relation("ScoreOverrideEditor")
  promotionSnapshots     StudentPromotionSnapshot[]
  parentOfLinks          ParentStudentLink[] @relation("ParentOf")
  studentOfParentLinks   ParentStudentLink[] @relation("StudentOf")
  proctoringEvents         ProctoringEvent[]
  gradingAuditsPerformed   GradingAuditLog[] @relation("GradingAuditActor")
  cohortMemberships        CohortMembership[]
  homeroomCohorts          SchoolCohort[]      @relation("HomeroomTeacher")
  cohortInstructorships    CohortInstructor[]
  cohortMessagesPosted     CohortMessage[]
  departmentInstructorships DepartmentInstructor[]
  studentDepartmentAffiliations StudentDepartmentAffiliation[]
  chairedDepartments     AcademicDepartment[] @relation("DepartmentChair")
  departmentMessagesPosted DepartmentMessage[]
  learningResourcesAuthored  LearningResource[] @relation("LearningResourceAuthor")
  retakeRequestsAsStudent    AssessmentRetakeRequest[] @relation("RetakeRequestStudent")
  retakeRequestsAsReviewer   AssessmentRetakeRequest[] @relation("RetakeRequestReviewer")
  courseCompletionCertificates CourseCompletionCertificate[]

  @@unique([organizationId, email])
  @@unique([organizationId, googleSub])
  @@index([organizationId])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  body      String?
  link      String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@index([userId, createdAt(sort: Desc)])
}

model UserInvite {
  id             String   @id @default(cuid())
  organizationId String
  email          String
  role           Role     @default(STUDENT)
  token          String   @unique
  expiresAt      DateTime
  createdAt      DateTime @default(now())
  createdById    String?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy    User?        @relation("InviteCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([organizationId])
}

model Course {
  id             String   @id @default(cuid())
  organizationId String
  title          String
  description    String?  @db.Text
  published      Boolean  @default(false)
  /// CA vs exam weighting uses Assessment.kind (QUIZ vs EXAM). Optional 1–3 for multi-semester rollups.
  gradeWeightContinuous Float            @default(0.4)
  gradeWeightExam       Float            @default(0.6)
  gradingScale          GradingScaleType @default(PERCENTAGE)
  /// Higher-ed credit hours (optional; used by transcript/reporting).
  creditHours           Float?
  academicTermId        String?
  createdById    String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy    User         @relation("CourseAuthor", fields: [createdById], references: [id], onDelete: Restrict)
  academicTerm AcademicTerm? @relation(fields: [academicTermId], references: [id], onDelete: SetNull)

  modules       Module[]
  enrollments   Enrollment[]
  assessments   Assessment[]
  chatMessages  CourseChatMessage[]
  courseCohorts CourseCohort[]
  courseDepartments CourseDepartment[]
  completionCertificates CourseCompletionCertificate[]

  @@index([organizationId])
  @@index([academicTermId])
}

/// Headless CMS strings per organization (no redeploy for copy changes)
model CmsEntry {
  id             String   @id @default(cuid())
  organizationId String
  key            String
  value          String   @db.Text
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, key])
  @@index([organizationId])
}

model BlogPost {
  id             String   @id @default(cuid())
  organizationId String
  slug           String
  title          String
  excerpt        String?  @db.Text
  body           String   @db.Text
  published      Boolean  @default(false)
  authorId       String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  author       User         @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@unique([organizationId, slug])
  @@index([organizationId, published])
}

model LearningResource {
  id             String               @id @default(cuid())
  organizationId String
  title          String
  description    String?              @db.Text
  kind           LearningResourceKind
  externalUrl    String?
  storageKey     String?              @unique
  mimeType       String?
  sortOrder      Int                  @default(0)
  published      Boolean              @default(true)
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  createdById    String?

  organization Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy    User?            @relation("LearningResourceAuthor", fields: [createdById], references: [id], onDelete: SetNull)
  progress     ResourceProgress[]

  @@index([organizationId, published])
  @@index([organizationId, createdById])
}

model ResourceProgress {
  id          String   @id @default(cuid())
  userId      String
  resourceId  String
  positionSec Float?
  percent     Float    @default(0)
  updatedAt   DateTime @updatedAt

  user     User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  resource LearningResource @relation(fields: [resourceId], references: [id], onDelete: Cascade)

  @@unique([userId, resourceId])
  @@index([resourceId])
}

model CourseChatMessage {
  id        String   @id @default(cuid())
  courseId  String
  userId    String
  body      String   @db.Text
  createdAt DateTime @default(now())

  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([courseId, createdAt])
}

/// Organization-wide chat visible to all members; platform operators can post from the console.
model OrganizationMessage {
  id               String               @id @default(cuid())
  organizationId   String
  senderKind       OrgMessageSenderKind
  userId           String?
  platformEmail    String?
  body             String               @db.Text
  createdAt        DateTime             @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User?        @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([organizationId, createdAt(sort: Desc)])
}

/// 1:1 DM thread between two org members (participants stored with deterministic ordering).
model DirectMessageThread {
  id                String   @id @default(cuid())
  organizationId    String
  participantLowId  String
  participantHighId String
  lastMessageAt     DateTime @default(now())

  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  participantLow  User         @relation("DmThreadLow", fields: [participantLowId], references: [id], onDelete: Cascade)
  participantHigh User         @relation("DmThreadHigh", fields: [participantHighId], references: [id], onDelete: Cascade)
  messages        DirectMessage[]

  @@unique([organizationId, participantLowId, participantHighId])
  @@index([organizationId])
  @@index([participantLowId])
  @@index([participantHighId])
  @@index([organizationId, lastMessageAt(sort: Desc)])
}

model DirectMessage {
  id        String   @id @default(cuid())
  threadId  String
  senderId  String
  body      String   @db.Text
  createdAt DateTime @default(now())

  thread DirectMessageThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  sender User                @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([threadId, createdAt])
}

model Module {
  id       String @id @default(cuid())
  courseId String
  title    String
  order    Int    @default(0)

  course  Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons Lesson[]

  @@index([courseId])
}

model Lesson {
  id        String  @id @default(cuid())
  moduleId  String
  title     String
  content   String? @db.Text
  order     Int     @default(0)
  videoUrl  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  module   Module         @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  files    LessonFile[]
  progress LessonProgress[]

  @@index([moduleId])
}

model LessonFile {
  id         String   @id @default(cuid())
  lessonId   String
  name       String
  url        String
  mimeType   String?
  /// Relative path under upload root; null = external URL only (see `url`)
  storageKey String?  @unique
  createdAt  DateTime @default(now())

  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@index([lessonId])
}

model Enrollment {
  id               String   @id @default(cuid())
  userId           String
  courseId         String
  enrolledAt       DateTime @default(now())
  progressPercent  Float    @default(0)

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@index([courseId])
}

/// Course completion credential for public verification (QR / credential ID on printed certificates).
model CourseCompletionCertificate {
  id             String   @id @default(cuid())
  organizationId String
  userId         String
  courseId       String
  issuedAt       DateTime
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  course       Course       @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@index([organizationId])
}

model LessonProgress {
  id          String   @id @default(cuid())
  userId      String
  lessonId    String
  completedAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
  @@index([lessonId])
}

model Assessment {
  id               String         @id @default(cuid())
  courseId         String
  title            String
  description      String?        @db.Text
  kind             AssessmentKind @default(QUIZ)
  /// 1, 2, or 3 for multi-semester promotion rollups; null = not tagged to a semester.
  semester         Int?
  timeLimitMinutes Int?
  published        Boolean        @default(false)
  /// When true, students cannot start a new attempt; those with an in-progress draft may still save and submit.
  studentAttemptsLocked Boolean   @default(false)
  shuffleQuestions Boolean        @default(false)
  shuffleOptions   Boolean        @default(false)
  /// When false, students (and submission API for students) do not see keys, correct answers, or full question payloads after submit.
  showAnswersToStudents  Boolean @default(true)
  /// Submitted attempts allowed without an approved retake grant (minimum 1).
  maxAttemptsPerStudent  Int     @default(1)
  /// After max attempts, student may request another attempt for staff approval.
  retakeRequiresApproval Boolean @default(true)
  /// Student take UI: no integrity UI / monitored + leave warnings / stricter copy & context-menu limits.
  deliveryMode     AssessmentDeliveryMode @default(FORMATIVE)
  createdById      String
  /// Optional: when this assessment appears / is due on the school dashboard calendar (staff set on edit page).
  availableFrom    DateTime?
  dueAt            DateTime?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  course      Course       @relation(fields: [courseId], references: [id], onDelete: Cascade)
  createdBy   User         @relation("AssessmentAuthor", fields: [createdById], references: [id], onDelete: Restrict)
  questions   Question[]
  submissions Submission[]
  questionPools AssessmentQuestionPool[]
  assessmentCohorts AssessmentCohort[]
  assessmentDepartments AssessmentDepartment[]
  retakeRequests AssessmentRetakeRequest[]
  scheduleEntries AssessmentScheduleEntry[]

  @@index([courseId])
  /// Published-assessment scans (platform outcome rollups, org-level stats).
  @@index([published, courseId])
}

model AssessmentScheduleEntry {
  id           String                 @id @default(cuid())
  assessmentId String
  kind         AssessmentScheduleKind
  startsAt     DateTime
  endsAt       DateTime?
  allDay       Boolean                @default(false)
  label        String?                @db.VarChar(200)
  sortOrder    Int                    @default(0)
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt

  assessment Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)

  @@index([assessmentId])
  @@index([startsAt])
}

model AssessmentRetakeRequest {
  id               String              @id @default(cuid())
  assessmentId     String
  userId           String
  fromSubmissionId String?
  status           RetakeRequestStatus @default(PENDING)
  reviewedById     String?
  reviewedAt       DateTime?
  studentNote      String?             @db.Text
  staffNote        String?             @db.Text
  consumedAt       DateTime?
  createdAt        DateTime            @default(now())

  assessment     Assessment  @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  user           User        @relation("RetakeRequestStudent", fields: [userId], references: [id], onDelete: Cascade)
  reviewer       User?       @relation("RetakeRequestReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)
  fromSubmission Submission? @relation(fields: [fromSubmissionId], references: [id], onDelete: SetNull)

  @@index([assessmentId, status])
  @@index([userId, assessmentId])
}

model Question {
  id              String       @id @default(cuid())
  assessmentId    String
  type            QuestionType
  prompt          String       @db.Text
  order           Int          @default(0)
  points          Float        @default(1)
  /// MCQ: { "choices": [{ "id": string, "text": string, "correct": boolean }] }
  options         Json?
  correctAnswer   String?
  markingScheme   String?      @db.Text
  /// Optional multimodal refs: [{ "kind": "image"|"video"|"audio", "url": "https://..." }]
  mediaAttachments Json?
  /// Rubric criteria JSON (aligned with reporting_engine / grading UI).
  rubric             Json?
  /// Engine metadata for DRAG_DROP / FORMULA / ESSAY_RICH (versioned contract).
  questionSchema     Json?

  assessment Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  answers    Answer[]
  poolEntries AssessmentPoolEntry[]
  standards  QuestionStandard[]

  @@index([assessmentId])
}

/// Draw N questions from a named pool when building a take session.
model AssessmentQuestionPool {
  id           String   @id @default(cuid())
  assessmentId String
  name         String   @default("Pool")
  drawCount    Int      @default(1)
  sortOrder    Int      @default(0)

  assessment Assessment            @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  entries    AssessmentPoolEntry[]

  @@index([assessmentId])
}

model AssessmentPoolEntry {
  id         String @id @default(cuid())
  poolId     String
  questionId String

  pool     AssessmentQuestionPool @relation(fields: [poolId], references: [id], onDelete: Cascade)
  question Question               @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([poolId, questionId])
  @@index([questionId])
}

model Submission {
  id          String           @id @default(cuid())
  assessmentId String
  userId      String
  startedAt   DateTime         @default(now())
  submittedAt DateTime?
  status      SubmissionStatus @default(DRAFT)
  totalScore  Float?
  maxScore    Float?
  moderationState SubmissionModerationState @default(NONE)

  assessment Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  answers    Answer[]
  retakeRequestsOriginating AssessmentRetakeRequest[]

  @@index([assessmentId])
  @@index([assessmentId, status])
  @@index([userId])
}

model Answer {
  id            String  @id @default(cuid())
  submissionId  String
  questionId    String
  content       String  @db.Text
  autoGraded    Boolean @default(false)
  score         Float?
  aiScore       Float?
  aiFeedback    String? @db.Text
  manualScore   Float?
  manualComment String? @db.Text
  gradedById    String?
  manualEditedAt DateTime?
  /// Per-criterion rubric scores: [{ criterionId, points, maxPoints }]
  rubricScores   Json?
  /// Highlights / offsets / voice note URL fragments (see reporting_engine).
  annotations    Json?

  submission Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  question   Question   @relation(fields: [questionId], references: [id], onDelete: Cascade)
  gradedBy   User?      @relation("AnswerGradedBy", fields: [gradedById], references: [id], onDelete: SetNull)
  overrideLogs ScoreOverrideLog[]

  @@unique([submissionId, questionId])
  @@index([questionId])
}

model ScoreOverrideLog {
  id                  String   @id @default(cuid())
  answerId            String
  organizationId      String
  editorId            String
  previousManualScore Float?
  newManualScore      Float
  createdAt           DateTime @default(now())

  answer       Answer       @relation(fields: [answerId], references: [id], onDelete: Cascade)
  editor       User         @relation("ScoreOverrideEditor", fields: [editorId], references: [id], onDelete: Restrict)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, createdAt(sort: Desc)])
  @@index([answerId])
}

model StudentPromotionSnapshot {
  id                   String            @id @default(cuid())
  organizationId       String
  userId               String
  academicYearLabel    String
  semester1AvgPercent  Float?
  semester2AvgPercent  Float?
  semester3AvgPercent  Float?
  cumulativeAvgPercent Float?
  standing             PromotionStanding
  computedAt           DateTime          @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId, academicYearLabel])
  @@index([organizationId])
}
